{
  "name": "rider-alerts",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "tw:build": "tailwindcss -i src/tailwind.css -o src/generated/tailwind.css",
    "tw:watch": "tailwindcss -i src/tailwind.css -o src/generated/tailwind.css --watch",
    "prestart": "npm run tw:build",
    "start": "concurrently -k -n TW,NG -c cyan,magenta \"npm run tw:watch\" \"ng serve\"",
    "prebuild": "npm run tw:build",
    "build": "ng build",
    "watch": "ng build --watch",
    "pretest": "npm run tw:build",
    "test": "ng test",
    "clean": "ng cache clean && npx rimraf dist",
    "clean:cache": "ng cache clean",
    "cache:disable": "ng cache disable",
    "cache:enable": "ng cache enable"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "packageManager": "npm@10.9.2",
  "dependencies": {
    "@angular/animations": "^21.0.0",
    "@angular/common": "^21.0.0",
    "@angular/compiler": "^21.0.0",
    "@angular/core": "^21.0.0",
    "@angular/forms": "^21.0.0",
    "@angular/material": "^21.0.5",
    "@angular/platform-browser": "^21.0.0",
    "@angular/router": "^21.0.0",
    "@ngrx/effects": "^21.0.1",
    "@ngrx/entity": "^21.0.1",
    "@ngrx/store": "^21.0.1",
    "@ngrx/store-devtools": "^21.0.1",
    "ngrx-store-localstorage": "^20.1.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.0.4",
    "@angular/cli": "^21.0.4",
    "@angular/compiler-cli": "^21.0.0",
    "@tailwindcss/cli": "^4.3.3",
    "@tailwindcss/postcss": "^4.3.3",
    "autoprefixer": "^10.4.23",
    "concurrently": "^9.2.4",
    "jsdom": "^27.1.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.18",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8"
  }
}
